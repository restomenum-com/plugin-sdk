# Restomenum örnek eklenti — ortam değişkenleri
# `cp .env.example .env` → doldur → `npm start`  (= node --env-file=.env src/index.mjs; Node 20+)

# Portal → eklenti sayfasından alınır
CLIENT_ID=your-plugin-id
CLIENT_SECRET=cs_xxxxxxxxxxxxxxxxxxxxxxxx   # "Client Secret üret" — yalnız bir kez gösterilir, sakla

# Restomenum plugin API kökü (dev/sandbox veya production)
RESTOMENUM_BASE=https://sandbox.plugins.restomenum.app
# RESTOMENUM_BASE=https://plugins.restomenum.app

# Bu sunucunun herkese açık https kökü (manifest webhookUrl/connectUrl ile AYNI registered domain olmalı)
# Yerelde test için ngrok/cloudflared ile https tünel aç ve buraya yaz.
PUBLIC_URL=https://your-tunnel.example.com

PORT=3000

# (opsiyonel) `npm run test:api` için kurulumun apiKey'i (token exchange'te döner): serverId.pluginId.secret
# API_KEY=srv_xxx.plg_xxx.secret_xxx
